#!/usr/bin/env -S fontforge -quiet
# -*- mode: python; coding: utf-8 -*-

import os, sys, argparse
from enum import Enum

sys.path.append("%s/git/dse.d/my-python/src/my_python_dse" % os.environ["HOME"])
from font_utils import silence, get_fonts_in, u
from font_spacing_utils import get_font_spacing_type, FontSpacing

silence.on()
import fontforge
silence.off()

class Exactness(Enum):
    EXACT = 0
    ALL_GLYPHS_ARE_CLOSE = 1
    MOST_GLYPHS_ARE_CLOSE = 2
    @classmethod
    def nameof(cls, value):
        if value == Exactness.EXACT:
            return "exact"
        if value == Exactness.ALL_GLYPHS_ARE_CLOSE:
            return "all glyphs are close"
        if value == Exactness.MOST_GLYPHS_ARE_CLOSE:
            return "most glyphs are close"
    @classmethod
    def shortnameof(cls, value):
        if value == Exactness.EXACT:
            return "exact"
        if value == Exactness.ALL_GLYPHS_ARE_CLOSE:
            return "close"
        if value == Exactness.MOST_GLYPHS_ARE_CLOSE:
            return "kinda"

def main():
    global args
    parser = argparse.ArgumentParser()
    parser.add_argument('filenames', nargs='+', metavar='filename')
    args = parser.parse_args()

    for font_data in get_fonts_in(args.filenames, names=True):
        font = font_data.font
        filename = font_data.filename_open
        spacing_type = get_font_spacing_type(font)
        exactness = Exactness.EXACT
        if spacing_type == FontSpacing.PROPORTIONAL:
            spacing_type = get_font_spacing_type(font, fudge=1.01)
            exactness = Exactness.ALL_GLYPHS_ARE_CLOSE
            if spacing_type == FontSpacing.PROPORTIONAL:
                spacing_type = get_font_spacing_type(font, confidence=0.95, fudge=1.01)
                exactness = Exactness.MOST_GLYPHS_ARE_CLOSE
        print("%-4s  %-4s  %s" % (
            FontSpacing.shortnameof(spacing_type),
            Exactness.shortnameof(exactness),
            filename
        ))

main()

